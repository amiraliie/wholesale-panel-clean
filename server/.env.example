# App
NODE_ENV=production
PORT=4000

# Public URLs
APP_URL=https://panel.example.com
API_URL=https://panel.example.com/api
CORS_ORIGIN=https://panel.example.com
SUBSCRIPTION_PUBLIC_URL=https://panel.example.com/sub

# Database
DATABASE_URL=postgresql://panel_user:change_this_password@127.0.0.1:5432/wholesale_panel

# Auth
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-this-to-a-long-random-string-too

# Encryption
ENCRYPTION_KEY=change-this-to-a-secure-random-secret

# 3x-ui
THREEXUI_TIMEOUT=30000
THREEXUI_RETRY_ATTEMPTS=2

# Security
BCRYPT_ROUNDS=12

# Payment receipts
RECEIPT_UPLOAD_DIR=./uploads/receipts
