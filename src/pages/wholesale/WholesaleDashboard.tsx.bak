import { DashboardLayout } from '../../components/layout/DashboardLayout';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/Card';
import { StatsCard } from '../../components/StatsCard';
import { EmptyState, ErrorState, LoadingState } from '../../components/RemoteState';
import { useRemoteData } from '../../hooks/useRemoteData';
import { backend } from '../../services/backend';
import { formatDate, formatPrice } from '../../lib/utils';
import { Activity, CalendarClock, ShoppingCart, Wallet } from 'lucide-react';

export default function WholesaleDashboard() {
  const { data, isLoading, error, reload } = useRemoteData(async()=>({
    wallet: await backend.wallet.current(),
    endUsers: await backend.endUsers.list(),
    orders: await backend.orders.list()
  }), []);

  if (isLoading) return <DashboardLayout title="داشبورد"><LoadingState/></DashboardLayout>;
  if (error || !data) return <DashboardLayout title="داشبورد"><ErrorState message={error || 'خطا'} onRetry={reload}/></DashboardLayout>;

  const active = data.endUsers.filter((u:any)=>u.status==='active').length;
  const spent = data.orders.filter((o:any)=>o.status==='completed').reduce((sum:any,o:any)=>sum+Number(o.totalPrice||0),0);
  const expiringSoon = data.endUsers.filter((u:any)=>new Date(u.expiryTime).getTime() < Date.now()+7*86400000).length;

  return (
    <DashboardLayout title="داشبورد">
      <div className="space-y-6">
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <StatsCard title="موجودی" value={formatPrice(Number((data.wallet as any).balance||0))} icon={Wallet}/>
          <StatsCard title="کانفیگ فعال" value={active} icon={Activity}/>
          <StatsCard title="سفارش‌ها" value={data.orders.length} icon={ShoppingCart}/>
          <StatsCard title="نزدیک انقضا" value={expiringSoon} icon={CalendarClock}/>
        </div>
        <Card>
          <CardHeader><CardTitle>آخرین کانفیگ‌ها</CardTitle></CardHeader>
          <CardContent>
            {data.endUsers.length===0 ? <EmptyState/> :
              <div className="space-y-3">
                {data.endUsers.slice(0,6).map((u:any)=>
                  <div key={u.id} className="flex justify-between border-b border-gray-100 dark:border-gray-700 pb-2">
                    <span className="text-sm">{u.email}</span>
                    <span className="text-sm text-gray-500">انقضا: {formatDate(u.expiryTime)}</span>
                  </div>
                )}
              </div>
            }
            <p className="mt-4 text-sm text-gray-500">کل هزینه تکمیل‌شده: {formatPrice(spent)}</p>
          </CardContent>
        </Card>
      </div>
    </DashboardLayout>
  );
}
